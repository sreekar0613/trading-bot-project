#!/bin/bash
# pre-commit hook: block API key leaks before they hit the repo
# Place at .git/hooks/pre-commit and chmod +x

set -e

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo "Running pre-commit security check..."

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

FAIL=0

# Patterns that indicate hardcoded secrets
SECRET_PATTERNS=(
  # Generic API key shapes
  'sk-[a-zA-Z0-9]{20,}'              # OpenAI / ElevenLabs style keys
  '[a-zA-Z0-9]{32,}'                 # Long random strings (conservative â€” will flag some false positives)
  # Known prefixes
  'Bearer [a-zA-Z0-9\-_\.]{20,}'
  'xi-api-key.*[:=].*[a-zA-Z0-9]{20,}'
  'X-Api-Key.*[:=].*[a-zA-Z0-9]{20,}'
  # Env var name assigned to a literal value (not os.environ)
  'HEYGEN_API_KEY\s*=\s*["\x27][^"\x27$]'
  'ELEVENLABS_API_KEY\s*=\s*["\x27][^"\x27$]'
  'PHOTON_API_KEY\s*=\s*["\x27][^"\x27$]'
  'OPENAI_API_KEY\s*=\s*["\x27][^"\x27$]'
  'MONGO_URI\s*=\s*["\x27]mongodb'
  'WEBSOCKET_URL\s*=\s*["\x27]ws'
)

# File extensions to check
CHECK_EXTENSIONS=('.py' '.js' '.ts' '.json' '.yaml' '.yml' '.env' '.sh' '.md')

for FILE in $STAGED_FILES; do
  # Skip binary files
  if file "$FILE" | grep -q "binary"; then
    continue
  fi

  # Check extension
  EXT=".${FILE##*.}"
  SHOULD_CHECK=0
  for EXT_CHECK in "${CHECK_EXTENSIONS[@]}"; do
    if [ "$EXT" = "$EXT_CHECK" ]; then
      SHOULD_CHECK=1
      break
    fi
  done

  # Also check files with no extension (like pre-commit itself)
  if [ "$SHOULD_CHECK" -eq 0 ] && [[ "$FILE" != *.* ]]; then
    SHOULD_CHECK=1
  fi

  if [ "$SHOULD_CHECK" -eq 0 ]; then
    continue
  fi

  # Skip .env.example and test fixture files
  if [[ "$FILE" == *".env.example"* ]] || [[ "$FILE" == *"fixture"* ]] || [[ "$FILE" == *"test_"* ]]; then
    continue
  fi

  for PATTERN in "${SECRET_PATTERNS[@]}"; do
    MATCH=$(git diff --cached -U0 "$FILE" | grep '^+' | grep -v '^+++' | grep -E "$PATTERN" || true)
    if [ -n "$MATCH" ]; then
      echo -e "${RED}BLOCKED: Possible secret in $FILE${NC}"
      echo -e "${YELLOW}Pattern: $PATTERN${NC}"
      echo -e "${YELLOW}Match: $MATCH${NC}"
      echo ""
      FAIL=1
    fi
  done
done

# Block .env files from being committed (except .env.example)
for FILE in $STAGED_FILES; do
  if [[ "$FILE" == ".env" ]] || [[ "$FILE" == *"/.env" ]]; then
    echo -e "${RED}BLOCKED: .env file staged for commit: $FILE${NC}"
    echo "Add .env to .gitignore"
    FAIL=1
  fi
done

if [ "$FAIL" -eq 1 ]; then
  echo -e "${RED}Commit blocked. Remove secrets before committing.${NC}"
  echo "If this is a false positive, use: git commit --no-verify"
  exit 1
fi

echo "Security check passed."
exit 0
